# GWS CLI 用環境変数
# このファイルをコピーして .env を作成してください:
#   cp .env.example .env
#   source .env  で環境変数がエクスポートされます

# ─── GCP プロジェクト ───
export GCP_PROJECT_ID="your-gcp-project-id"

# ─── OAuth クライアント（GWS CLI 認証用） ───
# GCP Console > APIs & Services > Credentials で「デスクトップアプリ」として作成
export GOOGLE_WORKSPACE_CLI_CLIENT_ID="your-client-id.apps.googleusercontent.com"
export GOOGLE_WORKSPACE_CLI_CLIENT_SECRET="your-client-secret"

# ─── ユースケース別の設定 ───

# UC1: Slides テンプレート量産
export SLIDES_PRESENTATION_ID=""     # テンプレートのプレゼンテーション ID

# UC2: Gmail → Drive 自動保存
export DRIVE_UPLOAD_FOLDER_ID=""     # アップロード先の Drive フォルダ ID

# UC3: GitHub Issues + Gmail → Sheets
export SPREADSHEET_ID=""             # 転記先のスプレッドシート ID
export GITHUB_REPO=""                # GitHub リポジトリ (owner/repo)

# UC4: GA4 runReport 汎用 CLI
# ADC 認証が前提:
#   gcloud auth application-default login \
#     --scopes="https://www.googleapis.com/auth/analytics.readonly,https://www.googleapis.com/auth/cloud-platform"
export GA4_PROPERTY_ID=""            # GA4 プロパティ ID（数値のみ、例: 375307567）
export GA4_QUOTA_PROJECT=""          # API quota 用 GCP プロジェクト（例: iwai-personal-tools）
