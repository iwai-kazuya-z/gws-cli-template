{
  "permissions": {
    "deny": [
      "Bash(*gws * delete*)",
      "Bash(*gws * trash*)",
      "Bash(*gws * remove*)",
      "Bash(*gws drive files update*--json*trashed*)",
      "Bash(*gws admin users delete*)",
      "Bash(*gws admin groups delete*)",
      "Bash(*gws gmail users messages send*)",
      "Bash(*gws gmail users drafts create*)",
      "Bash(*gws gmail users drafts send*)",
      "Bash(*gws calendar events delete*)",
      "Bash(*gws calendar events insert*--json*)",
      "Bash(*gws auth export*)",
      "Bash(*cat *.env*)",
      "Bash(*less *.env*)",
      "Bash(*head *.env*)",
      "Bash(*tail *.env*)",
      "Read(*.env*)",
      "Read(*credentials*)",
      "Read(*client_secret*)"
    ]
  }
}
